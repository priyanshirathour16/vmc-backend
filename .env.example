# Node.js Environment
NODE_ENV=development
SERVER_PORT=5000

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# Supabase Configuration
# Get these from: Dashboard > Settings > API Keys
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxxxx (secret key)
SUPABASE_ANON_KEY=sb_publishable_xxxxx (anon key)

# PostgreSQL Direct Connection (for migrations)
# Standard connection string: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_change_in_production
JWT_EXPIRY=24h
REFRESH_TOKEN_EXPIRY=7d

# Email Configuration (Nodemailer)
EMAIL_FROM=noreply@vmcreviews.com
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_app_password

# CAPTCHA Configuration
CAPTCHA_SECRET=your_captcha_secret_key

# File Upload
MAX_FILE_SIZE=5242880
UPLOAD_DIR=./uploads

# Feature Flags
ENABLE_EMAIL_VERIFICATION=true
ENABLE_FRAUD_DETECTION=true

# Redis (Optional - for future caching)
# REDIS_URL=redis://localhost:6379

# Logging
LOG_LEVEL=debug
