# Node.js Environment
NODE_ENV=development
SERVER_PORT=5000

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# Supabase Configuration
# Get these from: Dashboard > Settings > API Keys
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxxxx (secret key)
SUPABASE_ANON_KEY=sb_publishable_xxxxx (anon key)

# PostgreSQL Direct Connection (for migrations)
# Standard connection string: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_change_in_production
JWT_EXPIRY=24h
REFRESH_TOKEN_EXPIRY=7d

# Email Configuration (Zepto Mail)
# Get your API key from: https://zeptomail.zoho.com → Settings → API Keys
# The key value includes the "Zoho-enczapikey " prefix; copy it exactly.
# Email Configuration (Zepto Mail)
ZEPTO_MAIL_API_KEY=Zoho-enczapikey PHtE6r0LQuzsgm4np0BVt/O+QpWsZ9kv/u1ufQgUtt4RDaVQHU1cq9h6kjG+o00uUaFFHP/OyYM+57rJu+zXIz65PWlEDmqyqK3sx/VYSPOZsbq6x00YuVwdfk3YXIHmddRj0iHUuNzYNA==
ZEPTO_MAIL_FROM_EMAIL=noreply@irissecuritysolutions.in
ZEPTO_MAIL_FROM_NAME=noreply

# CAPTCHA Configuration
CAPTCHA_SECRET=your_captcha_secret_key

# File Upload
MAX_FILE_SIZE=5242880
UPLOAD_DIR=./uploads

# Feature Flags
ENABLE_EMAIL_VERIFICATION=true
ENABLE_FRAUD_DETECTION=true

# Redis (Optional - for future caching)
# REDIS_URL=redis://localhost:6379

# Logging
LOG_LEVEL=debug
